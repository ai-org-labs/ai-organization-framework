{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-requirement-coverage-record.schema.json",
  "title": "AOF Requirement Coverage Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "record_id",
    "recorded_at",
    "work_item_id",
    "work_item_ref",
    "coverage_status",
    "requirements",
    "coverage_summary",
    "forecast",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "requirement-coverage-record" },
    "record_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "coverage_status": {
      "type": "string",
      "enum": ["draft", "ready", "blocked", "completed"]
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requirement_id",
          "requirement_type",
          "source_ref",
          "title",
          "owner_ref",
          "acceptance_boundary",
          "status",
          "linked_work_item_refs",
          "evidence_refs"
        ],
        "properties": {
          "requirement_id": { "type": "string", "minLength": 1 },
          "requirement_type": {
            "type": "string",
            "enum": ["functional", "non_functional", "qif_quality_intent", "release_gate"]
          },
          "source_ref": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "owner_ref": { "type": "string", "minLength": 1 },
          "acceptance_boundary": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["covered", "partial", "blocked", "unstarted", "at_risk"]
          },
          "linked_work_item_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "blocker_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_requirements",
        "covered_count",
        "partial_count",
        "blocked_count",
        "at_risk_count",
        "unstarted_count"
      ],
      "properties": {
        "total_requirements": { "type": "integer", "minimum": 0 },
        "covered_count": { "type": "integer", "minimum": 0 },
        "partial_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "at_risk_count": { "type": "integer", "minimum": 0 },
        "unstarted_count": { "type": "integer", "minimum": 0 }
      }
    },
    "forecast": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "estimated_remaining_work_items",
        "estimated_token_cost_range",
        "forecast_boundary"
      ],
      "properties": {
        "estimated_remaining_work_items": { "type": "integer", "minimum": 0 },
        "estimated_token_cost_range": { "type": "string", "minLength": 1 },
        "burndown_ref": { "type": ["string", "null"] },
        "forecast_boundary": { "type": "string", "minLength": 1 }
      }
    },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
