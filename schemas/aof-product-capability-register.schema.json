{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-product-capability-register.schema.json",
  "title": "AOF Product Capability Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "recorded_at",
    "purpose",
    "capabilities"
  ],
  "properties": {
    "artifact_type": { "const": "product-capability-register" },
    "recorded_at": { "type": "string", "format": "date-time" },
    "purpose": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capability_id",
          "name",
          "description",
          "user_value",
          "first_version",
          "status"
        ],
        "properties": {
          "capability_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "user_value": { "type": "string", "minLength": 1 },
          "first_version": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["planned", "available", "improved", "deprecated", "removed"]
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
