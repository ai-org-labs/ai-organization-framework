{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-incident-recovery-record.schema.json",
  "title": "AOF Provider Incident Recovery Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "recovery_id",
    "recorded_at",
    "release_ref",
    "work_item_id",
    "work_item_ref",
    "candidate_ref",
    "approval_ref",
    "reproduction_ref",
    "rollback_ref",
    "outcome_ref",
    "learning_ref",
    "operator_acceptance_ref",
    "production_boundary_ref",
    "incident_scenario",
    "detection_signal",
    "severity",
    "containment_action",
    "rollback_decision",
    "recovery_action",
    "resume_decision",
    "operator_notification",
    "learning_update_ref",
    "governance_action",
    "recovery_status",
    "time_to_detect_boundary",
    "time_to_contain_boundary",
    "data_loss_boundary",
    "customer_impact_boundary",
    "stop_conditions",
    "evidence_refs",
    "verification_refs",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "provider-incident-recovery-record" },
    "recovery_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "release_ref": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "candidate_ref": { "type": "string", "minLength": 1 },
    "approval_ref": { "type": "string", "minLength": 1 },
    "reproduction_ref": { "type": "string", "minLength": 1 },
    "rollback_ref": { "type": "string", "minLength": 1 },
    "outcome_ref": { "type": "string", "minLength": 1 },
    "learning_ref": { "type": "string", "minLength": 1 },
    "operator_acceptance_ref": { "type": "string", "minLength": 1 },
    "production_boundary_ref": { "type": "string", "minLength": 1 },
    "incident_scenario": { "type": "string", "minLength": 1 },
    "detection_signal": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "containment_action": { "type": "string", "minLength": 1 },
    "rollback_decision": { "type": "string", "enum": ["not_required", "rollback_ready", "rollback_executed", "blocked", "escalate"] },
    "recovery_action": { "type": "string", "minLength": 1 },
    "resume_decision": { "type": "string", "enum": ["resume_blocked", "resume_allowed", "defer", "escalate"] },
    "operator_notification": { "type": "string", "minLength": 1 },
    "learning_update_ref": { "type": "string", "minLength": 1 },
    "governance_action": { "type": "string", "enum": ["stop_provider_execution", "rollback_then_review", "escalate_to_human", "resume_after_review"] },
    "recovery_status": { "type": "string", "enum": ["ready_for_drill", "blocked", "not_ready"] },
    "time_to_detect_boundary": { "type": "string", "minLength": 1 },
    "time_to_contain_boundary": { "type": "string", "minLength": 1 },
    "data_loss_boundary": { "type": "string", "minLength": 1 },
    "customer_impact_boundary": { "type": "string", "minLength": 1 },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
