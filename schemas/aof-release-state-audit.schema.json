{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ai-org-labs/ai-organization-framework/schemas/aof-release-state-audit.schema.json",
  "title": "AOF Release State Audit",
  "type": "object",
  "required": [
    "ok",
    "artifact_type",
    "generated_at",
    "project_root",
    "active_release",
    "governance_audit_cutoff_task_id",
    "governance_audits",
    "checks",
    "errors"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "artifact_type": {
      "type": "string",
      "enum": ["release-state-audit"]
    },
    "generated_at": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "active_release": {
      "type": ["object", "null"]
    },
    "governance_audit_cutoff_task_id": {
      "type": "string"
    },
    "governance_audits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "ok",
          "artifact_type",
          "scoped_task_count",
          "failing_check_count",
          "error_count",
          "errors"
        ],
        "properties": {
          "name": { "type": "string" },
          "ok": { "type": "boolean" },
          "artifact_type": { "type": ["string", "null"] },
          "scoped_task_count": { "type": ["integer", "null"] },
          "failing_check_count": { "type": "integer" },
          "error_count": { "type": "integer" },
          "errors": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
