{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-outcome-evidence-record.schema.json",
  "title": "AOF Provider Outcome Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "outcome_id",
    "recorded_at",
    "approval_ref",
    "reproduction_ref",
    "rollback_ref",
    "target_operation_ref",
    "work_item_id",
    "session_ref",
    "expected_outcome",
    "observed_result",
    "outcome_status",
    "evidence_refs",
    "verification_refs",
    "semantic_truth_boundary",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "provider-outcome-evidence-record" },
    "outcome_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "approval_ref": { "type": "string", "minLength": 1 },
    "reproduction_ref": { "type": "string", "minLength": 1 },
    "rollback_ref": { "type": "string", "minLength": 1 },
    "target_operation_ref": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "session_ref": { "type": "string", "minLength": 1 },
    "expected_outcome": { "type": "string", "minLength": 1 },
    "observed_result": { "type": "string", "minLength": 1 },
    "outcome_status": {
      "type": "string",
      "enum": ["observed", "accepted", "corrected", "rollback_recommended", "blocked"]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "semantic_truth_boundary": { "type": "string", "minLength": 1 },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
