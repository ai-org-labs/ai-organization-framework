{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-cost-quota-boundary-record.schema.json",
  "title": "AOF Provider Cost Quota Boundary Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "boundary_id",
    "recorded_at",
    "release_ref",
    "work_item_id",
    "work_item_ref",
    "candidate_ref",
    "approval_ref",
    "incident_recovery_ref",
    "provider_scope",
    "budget_owner_ref",
    "budget_period",
    "max_estimated_cost",
    "max_actual_cost",
    "currency",
    "max_tokens",
    "max_provider_calls",
    "max_retry_count",
    "rate_limit_boundary",
    "quota_boundary",
    "billing_boundary",
    "overage_policy",
    "cost_status",
    "quota_status",
    "execution_eligibility",
    "governance_action",
    "stop_conditions",
    "evidence_refs",
    "verification_refs",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "provider-cost-quota-boundary-record" },
    "boundary_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "release_ref": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "candidate_ref": { "type": "string", "minLength": 1 },
    "approval_ref": { "type": "string", "minLength": 1 },
    "incident_recovery_ref": { "type": "string", "minLength": 1 },
    "provider_scope": { "type": "string", "minLength": 1 },
    "budget_owner_ref": { "type": "string", "minLength": 1 },
    "budget_period": { "type": "string", "minLength": 1 },
    "max_estimated_cost": { "type": ["number", "integer"], "exclusiveMinimum": 0 },
    "max_actual_cost": { "type": ["number", "integer"], "exclusiveMinimum": 0 },
    "currency": { "type": "string", "minLength": 1 },
    "max_tokens": { "type": "integer", "minimum": 1 },
    "max_provider_calls": { "type": "integer", "minimum": 1 },
    "max_retry_count": { "type": "integer", "minimum": 0 },
    "rate_limit_boundary": { "type": "string", "minLength": 1 },
    "quota_boundary": { "type": "string", "minLength": 1 },
    "billing_boundary": { "type": "string", "minLength": 1 },
    "overage_policy": { "type": "string", "enum": ["block", "escalate", "allow"] },
    "cost_status": { "type": "string", "enum": ["within_boundary", "at_risk", "exceeded", "not_ready"] },
    "quota_status": { "type": "string", "enum": ["within_boundary", "at_risk", "exceeded", "not_ready"] },
    "execution_eligibility": { "type": "string", "enum": ["allowed", "blocked", "escalated", "not_assessed"] },
    "governance_action": { "type": "string", "enum": ["allow_bounded_execution", "block_provider_execution", "escalate_budget_review", "defer_until_quota_known"] },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
