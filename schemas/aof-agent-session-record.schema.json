{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-agent-session-record.schema.json",
  "title": "AOF Agent Session Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "stream_format_version",
    "stream_id",
    "recorded_at",
    "session_id",
    "actor_ref",
    "role_ref",
    "provider",
    "model",
    "events",
    "links",
    "release_ready_evidence",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "agent-session-record" },
    "stream_format_version": { "type": "integer" },
    "stream_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "parent_session_id": { "type": ["string", "null"] },
    "actor_ref": { "type": "string", "minLength": 1 },
    "role_ref": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "event_type",
          "occurred_at",
          "summary"
        ],
        "properties": {
          "event_id": { "type": "string", "minLength": 1 },
          "event_type": {
            "type": "string",
            "enum": [
              "prompt",
              "response",
              "tool_call",
              "artifact_write",
              "verification_result",
              "risk_candidate",
              "decision_candidate",
              "council_review",
              "stop_condition"
            ]
          },
          "occurred_at": { "type": "string", "format": "date-time" },
          "summary": { "type": "string", "minLength": 1 },
          "artifact_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "tool_name": { "type": ["string", "null"] },
          "safety_level": {
            "type": ["string", "null"],
            "enum": [
              "safe_read",
              "safe_local_write",
              "project_write",
              "external_write",
              "dangerous",
              null
            ]
          },
          "approval_policy": { "type": ["string", "null"] }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_refs",
        "requirement_refs",
        "test_evidence_refs",
        "commit_refs",
        "pr_refs",
        "artifact_refs"
      ],
      "properties": {
        "task_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requirement_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "test_evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "commit_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "pr_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "artifact_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "risk_candidates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "decision_candidates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "release_ready_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim",
        "evidence_refs",
        "verdict"
      ],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "verdict": {
          "type": "string",
          "enum": [
            "not_ready",
            "structurally_ready",
            "runtime_ready",
            "operator_validated"
          ]
        }
      }
    },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
