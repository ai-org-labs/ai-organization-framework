{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-external-resource-audit.schema.json",
  "title": "AOF External Resource Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "artifact_type",
    "generated_at",
    "project_root",
    "summary",
    "resources",
    "uses",
    "checks",
    "errors"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "external-resource-audit" },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource_count",
        "ready_resource_count",
        "use_count",
        "approved_or_not_required_use_count",
        "blocked_use_count",
        "missing_boundary_count",
        "failing_check_count"
      ],
      "properties": {
        "resource_count": { "type": "integer", "minimum": 0 },
        "ready_resource_count": { "type": "integer", "minimum": 0 },
        "use_count": { "type": "integer", "minimum": 0 },
        "approved_or_not_required_use_count": { "type": "integer", "minimum": 0 },
        "blocked_use_count": { "type": "integer", "minimum": 0 },
        "missing_boundary_count": { "type": "integer", "minimum": 0 },
        "failing_check_count": { "type": "integer", "minimum": 0 }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource_id", "resource_kind", "display_name", "artifact_ref", "readiness_status", "allowed_operations"],
        "properties": {
          "resource_id": { "type": "string" },
          "resource_kind": { "type": "string" },
          "display_name": { "type": "string" },
          "artifact_ref": { "type": "string" },
          "readiness_status": { "type": "string" },
          "allowed_operations": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "uses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["use_id", "work_item_id", "resource_ref", "operation_type", "approval_status", "execution_status", "artifact_ref"],
        "properties": {
          "use_id": { "type": "string" },
          "work_item_id": { "type": "string" },
          "resource_ref": { "type": "string" },
          "operation_type": { "type": "string" },
          "approval_status": { "type": "string" },
          "execution_status": { "type": "string" },
          "artifact_ref": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
