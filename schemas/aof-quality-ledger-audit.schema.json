{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-quality-ledger-audit.schema.json",
  "title": "AOF Quality Ledger Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "artifact_type",
    "generated_at",
    "project_root",
    "ledger_root_ref",
    "summary",
    "events",
    "checks",
    "errors"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "quality-ledger-audit" },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string", "minLength": 1 },
    "ledger_root_ref": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_count",
        "blocking_event_count",
        "semantic_truth_claim_count",
        "operator_validated_count",
        "failing_check_count"
      ],
      "properties": {
        "event_count": { "type": "integer", "minimum": 0 },
        "blocking_event_count": { "type": "integer", "minimum": 0 },
        "semantic_truth_claim_count": { "type": "integer", "minimum": 0 },
        "operator_validated_count": { "type": "integer", "minimum": 0 },
        "failing_check_count": { "type": "integer", "minimum": 0 }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "event_type",
          "quality_intent_ref",
          "work_item_ref",
          "artifact_ref",
          "governance_action"
        ],
        "properties": {
          "event_id": { "type": "string" },
          "event_type": { "type": "string" },
          "quality_intent_ref": { "type": "string" },
          "work_item_ref": { "type": "string" },
          "artifact_ref": { "type": "string" },
          "governance_action": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
