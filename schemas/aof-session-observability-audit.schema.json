{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-session-observability-audit.schema.json",
  "title": "AOF Session Observability Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "artifact_type",
    "generated_at",
    "project_root",
    "summary",
    "streams",
    "checks",
    "errors"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "session-observability-audit" },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stream_count",
        "runtime_ready_stream_count",
        "failing_check_count"
      ],
      "properties": {
        "stream_count": { "type": "integer", "minimum": 0 },
        "runtime_ready_stream_count": { "type": "integer", "minimum": 0 },
        "failing_check_count": { "type": "integer", "minimum": 0 }
      }
    },
    "streams": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "session_id",
          "stream_ref",
          "source_task_id",
          "event_count",
          "release_verdict"
        ],
        "properties": {
          "session_id": { "type": "string", "minLength": 1 },
          "stream_ref": { "type": "string", "minLength": 1 },
          "source_task_id": { "type": "string", "minLength": 1 },
          "event_count": { "type": "integer", "minimum": 0 },
          "release_verdict": { "type": "string", "minLength": 1 }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
