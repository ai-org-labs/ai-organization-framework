{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-production-boundary-record.schema.json",
  "title": "AOF Provider Production Boundary Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "boundary_id",
    "recorded_at",
    "release_ref",
    "work_item_id",
    "work_item_ref",
    "mission_control_ref",
    "approval_ref",
    "reproduction_ref",
    "rollback_ref",
    "outcome_ref",
    "learning_ref",
    "operator_acceptance_ref",
    "product_value_evidence_ref",
    "provider_scope",
    "allowed_operation_class",
    "execution_eligibility",
    "production_execution_authorized",
    "credential_boundary",
    "budget_boundary",
    "revocation_boundary",
    "rollback_boundary",
    "monitoring_boundary",
    "incident_boundary",
    "human_go_no_go_boundary",
    "product_value_comprehension_boundary",
    "go_no_go_status",
    "governance_action",
    "stop_conditions",
    "provenance_refs",
    "verification_refs",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "provider-production-boundary-record" },
    "boundary_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "release_ref": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "mission_control_ref": { "type": "string", "minLength": 1 },
    "approval_ref": { "type": "string", "minLength": 1 },
    "reproduction_ref": { "type": "string", "minLength": 1 },
    "rollback_ref": { "type": "string", "minLength": 1 },
    "outcome_ref": { "type": "string", "minLength": 1 },
    "learning_ref": { "type": "string", "minLength": 1 },
    "operator_acceptance_ref": { "type": "string", "minLength": 1 },
    "product_value_evidence_ref": { "type": "string", "minLength": 1 },
    "provider_scope": { "type": "string", "minLength": 1 },
    "allowed_operation_class": {
      "type": "string",
      "enum": ["read_only", "write_preflight", "controlled_write_candidate", "production_write"]
    },
    "execution_eligibility": {
      "type": "string",
      "enum": ["candidate", "blocked", "not_assessed"]
    },
    "production_execution_authorized": { "type": "boolean" },
    "credential_boundary": { "type": "string", "minLength": 1 },
    "budget_boundary": { "type": "string", "minLength": 1 },
    "revocation_boundary": { "type": "string", "minLength": 1 },
    "rollback_boundary": { "type": "string", "minLength": 1 },
    "monitoring_boundary": { "type": "string", "minLength": 1 },
    "incident_boundary": { "type": "string", "minLength": 1 },
    "human_go_no_go_boundary": { "type": "string", "minLength": 1 },
    "product_value_comprehension_boundary": { "type": "string", "minLength": 1 },
    "go_no_go_status": {
      "type": "string",
      "enum": ["authorized", "not_authorized", "blocked", "escalated"]
    },
    "governance_action": {
      "type": "string",
      "enum": ["block_production_execution", "allow_preproduction_review", "escalate_production_review"]
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "provenance_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
