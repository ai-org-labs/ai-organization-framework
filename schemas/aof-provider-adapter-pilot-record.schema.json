{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-adapter-pilot-record.schema.json",
  "title": "AOF Provider Adapter Pilot Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "pilot_id",
    "recorded_at",
    "adapter_ref",
    "work_item_id",
    "work_item_ref",
    "session_ref",
    "pilot_mode",
    "approval_status",
    "approval_ref",
    "expected_external_effect",
    "allowed_actions",
    "denied_actions",
    "redaction_boundary",
    "rollback_plan",
    "provenance_refs",
    "verification_refs",
    "stop_conditions",
    "execution_status",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "provider-adapter-pilot-record" },
    "pilot_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "adapter_ref": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "session_ref": { "type": "string", "minLength": 1 },
    "pilot_mode": {
      "type": "string",
      "enum": ["dry_run", "read_only", "approved_write_simulation", "approved_external_write"]
    },
    "approval_status": {
      "type": "string",
      "enum": ["not_required", "approved", "pending", "rejected"]
    },
    "approval_ref": { "type": ["string", "null"] },
    "expected_external_effect": { "type": "string", "minLength": 1 },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "denied_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_boundary": { "type": "string", "minLength": 1 },
    "rollback_plan": { "type": "string", "minLength": 1 },
    "provenance_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "execution_status": {
      "type": "string",
      "enum": ["planned", "simulated", "executed", "blocked", "skipped"]
    },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
