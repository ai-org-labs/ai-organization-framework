{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-work-readiness-record.schema.json",
  "title": "AOF Work Readiness Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "record_id",
    "recorded_at",
    "work_item_id",
    "work_item_ref",
    "readiness_status",
    "goal",
    "risk",
    "loss_boundary",
    "acceptance_gates",
    "evidence_plan",
    "maker_role",
    "checker_role",
    "council_ref",
    "stop_conditions",
    "qif_refs",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "work-readiness-record" },
    "record_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "readiness_status": {
      "type": "string",
      "enum": ["ready", "blocked", "deferred"]
    },
    "goal": { "type": "string", "minLength": 1 },
    "risk": { "type": "string", "minLength": 1 },
    "loss_boundary": { "type": "string", "minLength": 1 },
    "acceptance_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_plan": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "maker_role": { "type": "string", "minLength": 1 },
    "checker_role": { "type": "string", "minLength": 1 },
    "council_ref": { "type": "string", "minLength": 1 },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "qif_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "archmap_impact_expected": {
      "type": "string",
      "enum": ["yes", "no", "unknown"]
    },
    "notes": { "type": ["string", "null"] },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] }
  }
}
