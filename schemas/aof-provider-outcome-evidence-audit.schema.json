{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-outcome-evidence-audit.schema.json",
  "title": "AOF Provider Outcome Evidence Audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "artifact_type", "generated_at", "project_root", "summary", "outcomes", "checks", "errors"],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "provider-outcome-evidence-audit" },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome_count", "accepted_count", "corrected_count", "rollback_recommended_count", "blocked_count", "missing_boundary_count", "failing_check_count"],
      "properties": {
        "outcome_count": { "type": "integer", "minimum": 0 },
        "accepted_count": { "type": "integer", "minimum": 0 },
        "corrected_count": { "type": "integer", "minimum": 0 },
        "rollback_recommended_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "missing_boundary_count": { "type": "integer", "minimum": 0 },
        "failing_check_count": { "type": "integer", "minimum": 0 }
      }
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["outcome_id", "approval_ref", "reproduction_ref", "rollback_ref", "target_operation_ref", "work_item_id", "outcome_status", "artifact_ref"],
        "properties": {
          "outcome_id": { "type": "string" },
          "approval_ref": { "type": "string" },
          "reproduction_ref": { "type": "string" },
          "rollback_ref": { "type": "string" },
          "target_operation_ref": { "type": "string" },
          "work_item_id": { "type": "string" },
          "outcome_status": { "type": "string" },
          "artifact_ref": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
