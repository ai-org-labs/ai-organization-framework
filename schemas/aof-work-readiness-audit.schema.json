{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-work-readiness-audit.schema.json",
  "title": "AOF Work Readiness Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "artifact_type",
    "generated_at",
    "project_root",
    "cutoff_task_id",
    "audited_status_dirs",
    "summary",
    "tasks",
    "readiness_records",
    "checks",
    "errors"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "work-readiness-audit" },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string", "minLength": 1 },
    "cutoff_task_id": { "type": "string", "minLength": 1 },
    "audited_status_dirs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scoped_task_count",
        "readiness_record_count",
        "ready_record_count",
        "missing_readiness_record_count",
        "failing_check_count"
      ],
      "properties": {
        "scoped_task_count": { "type": "integer", "minimum": 0 },
        "readiness_record_count": { "type": "integer", "minimum": 0 },
        "ready_record_count": { "type": "integer", "minimum": 0 },
        "missing_readiness_record_count": { "type": "integer", "minimum": 0 },
        "failing_check_count": { "type": "integer", "minimum": 0 }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "title", "status", "status_dir", "artifact_ref"],
        "properties": {
          "task_id": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "status_dir": { "type": "string" },
          "artifact_ref": { "type": "string" }
        }
      }
    },
    "readiness_records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "task_ref",
          "readiness_ref",
          "readiness_status",
          "acceptance_gate_count",
          "evidence_plan_count",
          "stop_condition_count"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "task_ref": { "type": "string" },
          "readiness_ref": { "type": "string" },
          "readiness_status": { "type": "string" },
          "acceptance_gate_count": { "type": "integer", "minimum": 0 },
          "evidence_plan_count": { "type": "integer", "minimum": 0 },
          "stop_condition_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
