{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-session-export-record.schema.json",
  "title": "AOF Provider-Neutral Session Export Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "export_id",
    "recorded_at",
    "work_item_id",
    "work_item_ref",
    "export_status",
    "source_session_ref",
    "provider_source",
    "event_summaries",
    "links",
    "redaction_boundary",
    "release_ready_boundary",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "session-export-record" },
    "export_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "export_status": {
      "type": "string",
      "enum": ["draft", "ready", "blocked", "completed"]
    },
    "source_session_ref": { "type": "string", "minLength": 1 },
    "provider_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model", "source_format", "source_of_truth_boundary"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "source_format": { "type": "string", "minLength": 1 },
        "source_of_truth_boundary": { "type": "string", "minLength": 1 }
      }
    },
    "event_summaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id", "event_type", "summary", "artifact_refs"],
        "properties": {
          "event_id": { "type": "string", "minLength": 1 },
          "event_type": {
            "type": "string",
            "enum": ["prompt", "response", "tool_call", "artifact_write", "verification", "blocker", "stop_condition"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "artifact_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_refs",
        "requirement_refs",
        "test_evidence_refs",
        "artifact_refs",
        "risk_candidates",
        "decision_candidates",
        "release_ready_evidence_refs"
      ],
      "properties": {
        "task_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "requirement_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "test_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "artifact_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "risk_candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "decision_candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "release_ready_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "redaction_boundary": { "type": "string", "minLength": 1 },
    "release_ready_boundary": { "type": "string", "minLength": 1 },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
