{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-operator-acceptance-drill-audit.schema.json",
  "title": "AOF Operator Acceptance Drill Audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "artifact_type", "generated_at", "project_root", "summary", "drills", "checks", "errors"],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "operator-acceptance-drill-audit" },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_count",
        "accept_count",
        "stop_count",
        "rollback_count",
        "escalate_count",
        "defer_count",
        "missing_boundary_count",
        "failing_check_count"
      ],
      "properties": {
        "drill_count": { "type": "integer", "minimum": 0 },
        "accept_count": { "type": "integer", "minimum": 0 },
        "stop_count": { "type": "integer", "minimum": 0 },
        "rollback_count": { "type": "integer", "minimum": 0 },
        "escalate_count": { "type": "integer", "minimum": 0 },
        "defer_count": { "type": "integer", "minimum": 0 },
        "missing_boundary_count": { "type": "integer", "minimum": 0 },
        "failing_check_count": { "type": "integer", "minimum": 0 }
      }
    },
    "drills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["drill_id", "operator_ref", "work_item_id", "decision", "artifact_ref"],
        "properties": {
          "drill_id": { "type": "string" },
          "operator_ref": { "type": "string" },
          "work_item_id": { "type": "string" },
          "decision": { "type": "string" },
          "artifact_ref": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
