{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-external-reference-integrity-record.schema.json",
  "title": "AOF External Reference Integrity Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "record_id",
    "recorded_at",
    "external_ref",
    "external_ref_artifact_ref",
    "source_system",
    "url",
    "relationship",
    "source_of_truth",
    "sync_policy",
    "usage_purpose",
    "freshness_required",
    "observed_at",
    "freshness_status",
    "availability_status",
    "integrity_status",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "external-reference-integrity-record" },
    "record_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "external_ref": { "type": "string", "minLength": 1 },
    "external_ref_artifact_ref": { "type": "string", "minLength": 1 },
    "source_system": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "minLength": 1 },
    "relationship": { "type": "string", "minLength": 1 },
    "source_of_truth": { "type": "string", "minLength": 1 },
    "sync_policy": { "type": "string", "minLength": 1 },
    "usage_purpose": { "type": "string", "minLength": 1 },
    "freshness_required": { "type": "boolean" },
    "observed_at": { "type": "string", "format": "date-time" },
    "freshness_status": {
      "type": "string",
      "enum": ["not_required", "current", "stale", "unknown"]
    },
    "availability_status": {
      "type": "string",
      "enum": ["available", "unavailable", "not_checked"]
    },
    "integrity_status": {
      "type": "string",
      "enum": ["ready", "warning", "blocked", "accepted_residual_risk"]
    },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] }
  }
}
