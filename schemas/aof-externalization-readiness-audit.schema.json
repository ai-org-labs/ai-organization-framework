{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ai-org-labs/ai-organization-framework/schemas/aof-externalization-readiness-audit.schema.json",
  "title": "AOF Externalization Readiness Audit",
  "type": "object",
  "required": [
    "ok",
    "artifact_type",
    "generated_at",
    "project_root",
    "summary",
    "externalization_claims",
    "checks",
    "errors"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "externalization-readiness-audit" },
    "generated_at": { "type": "string" },
    "project_root": { "type": "string" },
    "summary": {
      "type": "object",
      "required": [
        "externalization_claim_count",
        "ready_claim_count",
        "blocked_claim_count",
        "missing_boundary_count",
        "failing_check_count"
      ],
      "properties": {
        "externalization_claim_count": { "type": "integer" },
        "ready_claim_count": { "type": "integer" },
        "blocked_claim_count": { "type": "integer" },
        "missing_boundary_count": { "type": "integer" },
        "failing_check_count": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "externalization_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "claim_type",
          "artifact_ref",
          "readiness_status",
          "source_of_truth",
          "permission_boundary",
          "freshness_boundary",
          "availability_boundary",
          "approval_boundary",
          "not_proven"
        ],
        "properties": {
          "claim_id": { "type": "string" },
          "claim_type": { "type": "string" },
          "artifact_ref": { "type": "string" },
          "readiness_status": { "type": "string" },
          "source_of_truth": { "type": "string" },
          "permission_boundary": { "type": "string" },
          "freshness_boundary": { "type": "string" },
          "availability_boundary": { "type": "string" },
          "approval_boundary": { "type": "string" },
          "not_proven": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "detail", "evidence_refs"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
