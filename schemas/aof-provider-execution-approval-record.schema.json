{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-execution-approval-record.schema.json",
  "title": "AOF Provider Execution Approval Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "approval_id",
    "recorded_at",
    "pilot_ref",
    "adapter_ref",
    "work_item_id",
    "work_item_ref",
    "session_ref",
    "approval_decision",
    "approved_execution_mode",
    "external_write_authorized",
    "execution_scope",
    "allowed_operations",
    "denied_operations",
    "side_effect_boundary",
    "redaction_boundary",
    "rollback_plan",
    "credential_boundary",
    "budget_boundary",
    "provenance_refs",
    "verification_refs",
    "stop_conditions",
    "production_execution_status",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "provider-execution-approval-record" },
    "approval_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "pilot_ref": { "type": "string", "minLength": 1 },
    "adapter_ref": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "session_ref": { "type": "string", "minLength": 1 },
    "approval_decision": {
      "type": "string",
      "enum": ["approved", "pending", "rejected", "blocked"]
    },
    "approved_execution_mode": {
      "type": "string",
      "enum": ["dry_run", "read_only", "bounded_external_write"]
    },
    "external_write_authorized": { "type": "boolean" },
    "human_approval_ref": { "type": ["string", "null"] },
    "execution_scope": { "type": "string", "minLength": 1 },
    "allowed_operations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "denied_operations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "side_effect_boundary": { "type": "string", "minLength": 1 },
    "redaction_boundary": { "type": "string", "minLength": 1 },
    "rollback_plan": { "type": "string", "minLength": 1 },
    "credential_boundary": { "type": "string", "minLength": 1 },
    "budget_boundary": { "type": "string", "minLength": 1 },
    "provenance_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "production_execution_status": {
      "type": "string",
      "enum": ["not_executed", "preflight_approved", "blocked", "executed"]
    },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
