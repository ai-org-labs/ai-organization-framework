{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-controlled-execution-candidate-record.schema.json",
  "title": "AOF Provider Controlled Execution Candidate Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "candidate_id",
    "recorded_at",
    "release_ref",
    "work_item_id",
    "work_item_ref",
    "mission_control_ref",
    "approval_ref",
    "target_operation_ref",
    "reproduction_ref",
    "rollback_ref",
    "outcome_ref",
    "learning_ref",
    "operator_acceptance_ref",
    "product_value_evidence_ref",
    "production_boundary_ref",
    "provider_scope",
    "controlled_execution_mode",
    "candidate_status",
    "expected_provider_effect",
    "external_write_authorized",
    "production_execution_authorized",
    "go_no_go_decision",
    "credential_boundary",
    "budget_boundary",
    "rollback_boundary",
    "monitoring_boundary",
    "incident_boundary",
    "stop_conditions",
    "provenance_refs",
    "verification_refs",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "provider-controlled-execution-candidate-record" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "release_ref": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "mission_control_ref": { "type": "string", "minLength": 1 },
    "approval_ref": { "type": "string", "minLength": 1 },
    "target_operation_ref": { "type": "string", "minLength": 1 },
    "reproduction_ref": { "type": "string", "minLength": 1 },
    "rollback_ref": { "type": "string", "minLength": 1 },
    "outcome_ref": { "type": "string", "minLength": 1 },
    "learning_ref": { "type": "string", "minLength": 1 },
    "operator_acceptance_ref": { "type": "string", "minLength": 1 },
    "product_value_evidence_ref": { "type": "string", "minLength": 1 },
    "production_boundary_ref": { "type": "string", "minLength": 1 },
    "provider_scope": { "type": "string", "minLength": 1 },
    "controlled_execution_mode": {
      "type": "string",
      "enum": ["dry_run_replay", "approved_preproduction_write_candidate", "blocked"]
    },
    "candidate_status": {
      "type": "string",
      "enum": ["ready_for_operator_go_no_go", "blocked", "not_ready"]
    },
    "expected_provider_effect": { "type": "string", "minLength": 1 },
    "external_write_authorized": { "type": "boolean" },
    "production_execution_authorized": { "type": "boolean" },
    "go_no_go_decision": {
      "type": "string",
      "enum": ["not_requested", "operator_go_required", "blocked", "defer", "approved_for_preproduction_only"]
    },
    "credential_boundary": { "type": "string", "minLength": 1 },
    "budget_boundary": { "type": "string", "minLength": 1 },
    "rollback_boundary": { "type": "string", "minLength": 1 },
    "monitoring_boundary": { "type": "string", "minLength": 1 },
    "incident_boundary": { "type": "string", "minLength": 1 },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "provenance_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
