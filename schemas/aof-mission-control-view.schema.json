{
  "type": "object",
  "required": [
    "view_type",
    "generated_at",
    "mission_overview",
    "artifact_graph",
    "runtime_position",
    "blockers",
    "next_action"
  ],
  "properties": {
    "view_type": {
      "const": "mission_control"
    },
    "generated_at": {
      "type": "string"
    },
    "mission_overview": {
      "type": "object",
      "required": [
        "mission",
        "release_version",
        "operating_goal",
        "next_value_slice",
        "current_runtime_stage"
      ],
      "properties": {
        "mission": { "type": ["string", "null"] },
        "release_version": { "type": ["string", "null"] },
        "release_definition_ref": { "type": ["string", "null"] },
        "operating_goal": { "type": ["string", "null"] },
        "next_value_slice": { "type": ["string", "null"] },
        "current_runtime_stage": { "type": ["string", "null"] },
        "chain_anchor_ref": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "artifact_graph": {
      "type": "object",
      "required": ["nodes", "edges", "current_node_id"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "kind", "state"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "kind": { "type": "string" },
              "state": { "type": "string" },
              "artifact_ref": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "relation"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "relation": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "current_node_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "runtime_position": {
      "type": "object",
      "required": ["current_phase", "current_step_label", "current_step_state"],
      "properties": {
        "current_phase": { "type": ["string", "null"] },
        "current_step_label": { "type": ["string", "null"] },
        "current_step_state": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["summary", "severity"],
        "properties": {
          "summary": { "type": "string" },
          "severity": { "type": "string" },
          "artifact_ref": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "next_action": {
      "type": "object",
      "required": ["recommended_action"],
      "properties": {
        "recommended_action": { "type": ["string", "null"] },
        "rationale": { "type": ["string", "null"] },
        "artifact_ref": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "work_governance": {
      "type": "object",
      "required": [
        "present",
        "artifact_root_ref",
        "benchmark_ref",
        "work_item_count",
        "work_items"
      ],
      "properties": {
        "present": { "type": "boolean" },
        "artifact_root_ref": { "type": "string" },
        "benchmark_ref": { "type": ["string", "null"] },
        "work_item_count": { "type": "integer" },
        "work_items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "work_item_id",
              "work_item_type",
              "objective",
              "reason_for_work",
              "council_review_need",
              "required_actor_roles",
              "required_skills",
              "selected_actors",
              "authority_boundaries",
              "council_status",
              "council_summary",
              "go_no_go_state",
              "go_no_go_summary",
              "operational_map_summary",
              "context_summary",
              "next_recommended_action",
              "refs"
            ],
            "properties": {
              "work_item_id": { "type": "string" },
              "work_item_type": { "type": "string" },
              "objective": { "type": "string" },
              "reason_for_work": { "type": "string" },
              "council_review_need": { "type": "string" },
              "required_actor_roles": { "type": "array", "items": { "type": "string" } },
              "required_skills": { "type": "array", "items": { "type": "string" } },
              "selected_actors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["actor_ref", "actor_type", "assigned_role", "output_required"],
                  "properties": {
                    "actor_ref": { "type": "string" },
                    "actor_type": { "type": "string" },
                    "assigned_role": { "type": "string" },
                    "output_required": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "authority_boundaries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["actor_ref", "authority_level", "must_not_decide"],
                  "properties": {
                    "actor_ref": { "type": "string" },
                    "authority_level": { "type": "string" },
                    "must_not_decide": { "type": "array", "items": { "type": "string" } }
                  },
                  "additionalProperties": false
                }
              },
              "council_status": { "type": ["string", "null"] },
              "council_summary": { "type": ["string", "null"] },
              "go_no_go_state": { "type": ["string", "null"] },
              "go_no_go_summary": { "type": ["string", "null"] },
              "operational_map_summary": { "type": ["string", "null"] },
              "context_summary": { "type": ["string", "null"] },
              "next_recommended_action": { "type": ["string", "null"] },
              "refs": {
                "type": "object",
                "required": [
                  "work_item_goal",
                  "actor_composition",
                  "council_ready_output",
                  "go_no_go_visualization",
                  "operational_map_change_log",
                  "context_pack",
                  "external_refs"
                ],
                "properties": {
                  "work_item_goal": { "type": ["string", "null"] },
                  "actor_composition": { "type": ["string", "null"] },
                  "council_ready_output": { "type": ["string", "null"] },
                  "go_no_go_visualization": { "type": ["string", "null"] },
                  "operational_map_change_log": { "type": ["string", "null"] },
                  "context_pack": { "type": ["string", "null"] },
                  "external_refs": { "type": "array", "items": { "type": "string" } }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "archmap": {
      "type": "object",
      "required": [
        "present",
        "current_source_ref",
        "impact_record_count",
        "latest_impact_ref",
        "latest_impact_status",
        "latest_work_item_id",
        "pending_impact_count",
        "pending_impacts",
        "source_of_truth",
        "external_refs"
      ],
      "properties": {
        "present": { "type": "boolean" },
        "current_source_ref": { "type": ["string", "null"] },
        "impact_record_count": { "type": "integer" },
        "latest_impact_ref": { "type": ["string", "null"] },
        "latest_impact_status": { "type": ["string", "null"] },
        "latest_work_item_id": { "type": ["string", "null"] },
        "pending_impact_count": { "type": "integer" },
        "pending_impacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["work_item_id", "status", "council_review_status", "artifact_ref"],
            "properties": {
              "work_item_id": { "type": ["string", "null"] },
              "status": { "type": ["string", "null"] },
              "council_review_status": { "type": ["string", "null"] },
              "artifact_ref": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "source_of_truth": { "type": "array", "items": { "type": "string" } },
        "external_refs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "skillful_actor_projection": {
      "type": ["object", "null"],
      "required": ["projection_ref", "projection_id", "actor", "visible_state", "proof_chain"],
      "properties": {
        "projection_ref": { "type": "string" },
        "projection_id": { "type": "string" },
        "actor": {
          "type": "object",
          "required": ["actor_ref", "role_ref", "team_ref", "character_label", "execution_mode"],
          "properties": {
            "actor_ref": { "type": ["string", "null"] },
            "role_ref": { "type": "string" },
            "team_ref": { "type": ["string", "null"] },
            "character_label": { "type": "string" },
            "execution_mode": { "type": "string" }
          },
          "additionalProperties": false
        },
        "visible_state": {
          "type": "object",
          "required": [
            "assignment_state",
            "execution_gate_state",
            "confidence_label",
            "benchmark_status",
            "council_review_needed",
            "speech_bubble",
            "current_action",
            "visible_blockers",
            "next_action"
          ],
          "properties": {
            "assignment_state": { "type": "string" },
            "execution_gate_state": { "type": "string" },
            "confidence_label": { "type": "string" },
            "benchmark_status": { "type": "string" },
            "council_review_needed": { "type": "boolean" },
            "speech_bubble": { "type": "string" },
            "current_action": { "type": "string" },
            "visible_blockers": {
              "type": "array",
              "items": { "type": "string" }
            },
            "next_action": { "type": "string" }
          },
          "additionalProperties": false
        },
        "proof_chain": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["step", "artifact_ref", "state"],
            "properties": {
              "step": { "type": "string" },
              "artifact_ref": { "type": "string" },
              "state": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "organization_state": {
      "type": "object",
      "required": [
        "present",
        "organization_ref",
        "topology",
        "council_count",
        "team_count",
        "role_count",
        "agent_count",
        "councils",
        "teams",
        "roles",
        "agents"
      ],
      "properties": {
        "present": { "type": "boolean" },
        "organization_ref": { "type": "string" },
        "topology": { "type": ["string", "null"] },
        "council_count": { "type": "integer" },
        "team_count": { "type": "integer" },
        "role_count": { "type": "integer" },
        "agent_count": { "type": "integer" },
        "councils": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["council_id", "name", "approval_policy", "mission", "responsibilities"],
            "properties": {
              "council_id": { "type": ["string", "null"] },
              "name": { "type": "string" },
              "approval_policy": { "type": ["string", "null"] },
              "mission": { "type": ["string", "null"] },
              "responsibilities": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "teams": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["team_id", "name", "mission", "dependencies", "responsibilities"],
            "properties": {
              "team_id": { "type": ["string", "null"] },
              "name": { "type": "string" },
              "mission": { "type": ["string", "null"] },
              "dependencies": { "type": "array", "items": { "type": "string" } },
              "responsibilities": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role_id", "name", "team_ref", "team_name", "mission", "authority", "assignment_count"],
            "properties": {
              "role_id": { "type": ["string", "null"] },
              "name": { "type": "string" },
              "team_ref": { "type": ["string", "null"] },
              "team_name": { "type": ["string", "null"] },
              "mission": { "type": ["string", "null"] },
              "authority": { "type": "array", "items": { "type": "string" } },
              "assignment_count": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["agent_id", "agent_type", "provider", "capabilities"],
            "properties": {
              "agent_id": { "type": ["string", "null"] },
              "agent_type": { "type": ["string", "null"] },
              "provider": { "type": ["string", "null"] },
              "capabilities": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "agent_session_observability": {
      "type": "object",
      "required": [
        "present",
        "artifact_root_ref",
        "audit_ref",
        "stream_count",
        "latest_session_id",
        "latest_session_ref",
        "latest_actor_ref",
        "latest_role_ref",
        "latest_recorded_at",
        "latest_event_count",
        "latest_release_verdict",
        "audit_ok",
        "audit_failing_check_count",
        "latest_audit_stream_ref",
        "linked_task_refs",
        "linked_requirement_refs",
        "linked_test_evidence_refs",
        "linked_artifact_refs",
        "risk_candidates",
        "decision_candidates",
        "latest_events",
        "latest_tool_calls"
      ],
      "properties": {
        "present": { "type": "boolean" },
        "artifact_root_ref": { "type": "string" },
        "audit_ref": { "type": ["string", "null"] },
        "stream_count": { "type": "integer" },
        "latest_session_id": { "type": ["string", "null"] },
        "latest_session_ref": { "type": ["string", "null"] },
        "latest_actor_ref": { "type": ["string", "null"] },
        "latest_role_ref": { "type": ["string", "null"] },
        "latest_recorded_at": { "type": ["string", "null"] },
        "latest_event_count": { "type": "integer" },
        "latest_release_verdict": { "type": ["string", "null"] },
        "audit_ok": { "type": ["boolean", "null"] },
        "audit_failing_check_count": { "type": ["integer", "null"] },
        "latest_audit_stream_ref": { "type": ["string", "null"] },
        "linked_task_refs": { "type": "array", "items": { "type": "string" } },
        "linked_requirement_refs": { "type": "array", "items": { "type": "string" } },
        "linked_test_evidence_refs": { "type": "array", "items": { "type": "string" } },
        "linked_artifact_refs": { "type": "array", "items": { "type": "string" } },
        "risk_candidates": { "type": "array", "items": { "type": "string" } },
        "decision_candidates": { "type": "array", "items": { "type": "string" } },
        "latest_events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["event_type", "summary", "occurred_at", "tool_name", "safety_level", "approval_policy", "artifact_refs"],
            "properties": {
              "event_type": { "type": "string" },
              "summary": { "type": "string" },
              "occurred_at": { "type": "string" },
              "tool_name": { "type": ["string", "null"] },
              "safety_level": { "type": ["string", "null"] },
              "approval_policy": { "type": ["string", "null"] },
              "artifact_refs": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "latest_tool_calls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["summary", "tool_name", "safety_level", "approval_policy"],
            "properties": {
              "summary": { "type": "string" },
              "tool_name": { "type": ["string", "null"] },
              "safety_level": { "type": ["string", "null"] },
              "approval_policy": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
