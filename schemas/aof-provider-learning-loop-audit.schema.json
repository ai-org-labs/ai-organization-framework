{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-learning-loop-audit.schema.json",
  "title": "AOF Provider Learning Loop Audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "artifact_type", "generated_at", "project_root", "summary", "learning_updates", "checks", "errors"],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "provider-learning-loop-audit" },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["learning_count", "updated_count", "escalated_count", "blocked_count", "missing_boundary_count", "failing_check_count"],
      "properties": {
        "learning_count": { "type": "integer", "minimum": 0 },
        "updated_count": { "type": "integer", "minimum": 0 },
        "escalated_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "missing_boundary_count": { "type": "integer", "minimum": 0 },
        "failing_check_count": { "type": "integer", "minimum": 0 }
      }
    },
    "learning_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["learning_id", "outcome_ref", "decision", "update_status", "artifact_ref"],
        "properties": {
          "learning_id": { "type": "string" },
          "outcome_ref": { "type": "string" },
          "decision": { "type": "string" },
          "update_status": { "type": "string" },
          "artifact_ref": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
