{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ai-org-labs/ai-organization-framework/schemas/aof-work-governance-benchmark.schema.json",
  "title": "AI Organization Framework Work Governance Benchmark",
  "type": "object",
  "required": [
    "artifact_type",
    "generated_at",
    "project_root",
    "work_items_evaluated",
    "artifacts_evaluated",
    "benchmarks"
  ],
  "properties": {
    "artifact_type": { "type": "string", "enum": ["work-governance-benchmark"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string" },
    "work_items_evaluated": { "type": "integer" },
    "artifacts_evaluated": { "type": "integer" },
    "benchmarks": {
      "type": "object",
      "required": ["WG-001", "WG-002", "WG-003", "WG-004", "WG-005", "WG-006", "WG-007"],
      "properties": {
        "WG-001": { "$ref": "#/$defs/benchmark_result" },
        "WG-002": { "$ref": "#/$defs/benchmark_result" },
        "WG-003": { "$ref": "#/$defs/benchmark_result" },
        "WG-004": { "$ref": "#/$defs/benchmark_result" },
        "WG-005": { "$ref": "#/$defs/benchmark_result" },
        "WG-006": { "$ref": "#/$defs/benchmark_result" },
        "WG-007": { "$ref": "#/$defs/benchmark_result" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "benchmark_result": {
      "type": "object",
      "required": ["status", "detail", "evidence"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "detail": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
