{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-execution-reproduction-audit.schema.json",
  "title": "AOF Provider Execution Reproduction Audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "artifact_type", "generated_at", "project_root", "summary", "reproductions", "checks", "errors"],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "provider-execution-reproduction-audit" },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reproduction_count", "reproduced_count", "blocked_count", "mismatch_count", "missing_boundary_count", "failing_check_count"],
      "properties": {
        "reproduction_count": { "type": "integer", "minimum": 0 },
        "reproduced_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "mismatch_count": { "type": "integer", "minimum": 0 },
        "missing_boundary_count": { "type": "integer", "minimum": 0 },
        "failing_check_count": { "type": "integer", "minimum": 0 }
      }
    },
    "reproductions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reproduction_id", "approval_ref", "target_operation_ref", "work_item_id", "result_status", "artifact_ref"],
        "properties": {
          "reproduction_id": { "type": "string" },
          "approval_ref": { "type": "string" },
          "target_operation_ref": { "type": "string" },
          "work_item_id": { "type": "string" },
          "result_status": { "type": "string" },
          "artifact_ref": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
