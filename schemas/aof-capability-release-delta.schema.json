{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-capability-release-delta.schema.json",
  "title": "AOF Capability Release Delta",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "delta_id",
    "recorded_at",
    "release_version",
    "release_ref",
    "work_item_id",
    "work_item_ref",
    "one_minute_value_explanation",
    "thirty_second_version_delta",
    "new_capability_ids",
    "updated_capability_ids",
    "removed_capability_ids",
    "value_evidence_refs",
    "product_review_trigger",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "capability-release-delta" },
    "delta_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "release_version": { "type": "string", "minLength": 1 },
    "release_ref": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "one_minute_value_explanation": { "type": "string", "minLength": 1 },
    "thirty_second_version_delta": { "type": "string", "minLength": 1 },
    "new_capability_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "updated_capability_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "removed_capability_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "value_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "product_review_trigger": { "type": "string", "minLength": 1 },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
