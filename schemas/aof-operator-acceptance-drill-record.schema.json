{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-operator-acceptance-drill-record.schema.json",
  "title": "AOF Operator Acceptance Drill Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "drill_id",
    "recorded_at",
    "operator_ref",
    "work_item_id",
    "approval_ref",
    "reproduction_ref",
    "rollback_ref",
    "outcome_ref",
    "learning_ref",
    "mission_control_ref",
    "decision",
    "decision_rationale",
    "accepted_risk",
    "blocker_summary",
    "next_action",
    "safety_boundary",
    "not_proven",
    "evidence_refs",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "operator-acceptance-drill-record" },
    "drill_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "operator_ref": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "approval_ref": { "type": "string", "minLength": 1 },
    "reproduction_ref": { "type": "string", "minLength": 1 },
    "rollback_ref": { "type": "string", "minLength": 1 },
    "outcome_ref": { "type": "string", "minLength": 1 },
    "learning_ref": { "type": "string", "minLength": 1 },
    "mission_control_ref": { "type": "string", "minLength": 1 },
    "decision": {
      "type": "string",
      "enum": ["accept", "stop", "rollback", "escalate", "defer"]
    },
    "decision_rationale": { "type": "string", "minLength": 1 },
    "accepted_risk": { "type": "string", "minLength": 1 },
    "blocker_summary": { "type": "string", "minLength": 1 },
    "next_action": { "type": "string", "minLength": 1 },
    "safety_boundary": { "type": "string", "minLength": 1 },
    "not_proven": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
