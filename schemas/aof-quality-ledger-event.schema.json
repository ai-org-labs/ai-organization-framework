{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-quality-ledger-event.schema.json",
  "title": "AOF Quality Ledger Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "ledger_format_version",
    "event_id",
    "recorded_at",
    "event_type",
    "quality_intent_ref",
    "work_item_ref",
    "claim",
    "evidence_refs",
    "qif_refs",
    "semantic_truth_claimed",
    "operator_validated",
    "governance_action"
  ],
  "properties": {
    "artifact_type": { "const": "quality-ledger-event" },
    "ledger_format_version": { "type": "integer", "const": 1 },
    "event_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "event_type": {
      "type": "string",
      "enum": [
        "evidence_added",
        "claim_contradicted",
        "runtime_evidence_missing",
        "assumption_corrected",
        "verdict_changed",
        "governance_escalation"
      ]
    },
    "quality_intent_ref": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "claim": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "qif_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "prior_state": { "type": ["string", "null"] },
    "new_state": { "type": ["string", "null"] },
    "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "semantic_truth_claimed": { "type": "boolean" },
    "operator_validated": { "type": "boolean" },
    "governance_action": {
      "type": "string",
      "enum": [
        "none",
        "review-required",
        "block-release",
        "request-evidence",
        "update-verdict"
      ]
    },
    "source_task_id": { "type": ["string", "null"] },
    "source_parent_session_id": { "type": ["string", "null"] },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
