{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-adapter-audit.schema.json",
  "title": "AOF Provider Adapter Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "artifact_type",
    "generated_at",
    "project_root",
    "summary",
    "adapters",
    "checks",
    "errors"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "const": "provider-adapter-audit" },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_count",
        "ready_adapter_count",
        "write_capable_adapter_count",
        "blocked_adapter_count",
        "missing_boundary_count",
        "failing_check_count"
      ],
      "properties": {
        "adapter_count": { "type": "integer", "minimum": 0 },
        "ready_adapter_count": { "type": "integer", "minimum": 0 },
        "write_capable_adapter_count": { "type": "integer", "minimum": 0 },
        "blocked_adapter_count": { "type": "integer", "minimum": 0 },
        "missing_boundary_count": { "type": "integer", "minimum": 0 },
        "failing_check_count": { "type": "integer", "minimum": 0 }
      }
    },
    "adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "adapter_id",
          "display_name",
          "adapter_kind",
          "operation_modes",
          "readiness_status",
          "artifact_ref"
        ],
        "properties": {
          "adapter_id": { "type": "string" },
          "display_name": { "type": "string" },
          "adapter_kind": { "type": "string" },
          "operation_modes": { "type": "array", "items": { "type": "string" } },
          "readiness_status": { "type": "string" },
          "artifact_ref": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
