{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ai-org-labs/ai-organization-framework/schemas/aof-evidence-independence-audit.schema.json",
  "title": "AOF Evidence Independence Audit",
  "type": "object",
  "required": [
    "ok",
    "artifact_type",
    "generated_at",
    "project_root",
    "cutoff_task_id",
    "audited_status_dirs",
    "independent_categories",
    "summary",
    "tasks",
    "evidence_records",
    "checks",
    "errors"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "type": "string", "enum": ["evidence-independence-audit"] },
    "generated_at": { "type": "string" },
    "project_root": { "type": "string" },
    "cutoff_task_id": { "type": "string" },
    "audited_status_dirs": { "type": "array", "items": { "type": "string" } },
    "independent_categories": { "type": "array", "items": { "type": "string" } },
    "summary": {
      "type": "object",
      "required": [
        "scoped_task_count",
        "evidence_record_count",
        "low_independence_task_count",
        "failing_check_count"
      ],
      "properties": {
        "scoped_task_count": { "type": "integer" },
        "evidence_record_count": { "type": "integer" },
        "low_independence_task_count": { "type": "integer" },
        "failing_check_count": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "title", "artifact_ref"],
        "properties": {
          "task_id": { "type": "string" },
          "title": { "type": "string" },
          "artifact_ref": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "evidence_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "evidence_ref_count", "independent_evidence_count", "categories"],
        "properties": {
          "task_id": { "type": "string" },
          "evidence_ref_count": { "type": "integer" },
          "independent_evidence_count": { "type": "integer" },
          "categories": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
