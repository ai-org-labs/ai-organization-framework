{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ai-org-labs/ai-organization-framework/schemas/aof-council-ready-output.schema.json",
  "title": "AI Organization Framework Council-ready Output",
  "type": "object",
  "required": [
    "artifact_type",
    "recorded_at",
    "work_item_id",
    "summary",
    "goal_achievement_status",
    "key_decisions_needed",
    "evidence_refs",
    "risks",
    "unresolved_questions",
    "go_no_go_recommendation",
    "visualization_refs",
    "downstream_impact",
    "required_human_approval"
  ],
  "properties": {
    "artifact_type": { "type": "string", "enum": ["council-ready-output"] },
    "recorded_at": { "type": "string", "format": "date-time" },
    "work_item_id": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "goal_achievement_status": {
      "type": "string",
      "enum": ["met", "partially-met", "not-met", "blocked", "not-yet-evaluated"]
    },
    "key_decisions_needed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unresolved_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "go_no_go_recommendation": {
      "type": "string",
      "enum": ["go", "no_go", "conditional_go", "needs_human_approval", "needs_more_evidence", "needs_rework"]
    },
    "visualization_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "downstream_impact": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_human_approval": { "type": "boolean" },
    "source_task_id": { "type": ["string", "null"] },
    "source_parent_session_id": { "type": ["string", "null"] },
    "source_decision_record_id": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
