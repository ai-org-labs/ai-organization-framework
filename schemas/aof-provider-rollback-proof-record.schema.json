{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-provider-rollback-proof-record.schema.json",
  "title": "AOF Provider Rollback Proof Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "rollback_id",
    "recorded_at",
    "approval_ref",
    "reproduction_ref",
    "target_operation_ref",
    "rollback_operation",
    "rollback_mode",
    "rollback_supported",
    "rollback_evidence_refs",
    "verification_refs",
    "stop_conditions",
    "result_status",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "provider-rollback-proof-record" },
    "rollback_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "approval_ref": { "type": "string", "minLength": 1 },
    "reproduction_ref": { "type": "string", "minLength": 1 },
    "target_operation_ref": { "type": "string", "minLength": 1 },
    "rollback_operation": { "type": "string", "minLength": 1 },
    "rollback_mode": { "type": "string", "enum": ["simulated", "dry_run", "blocked"] },
    "rollback_supported": { "type": "boolean" },
    "rollback_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "result_status": { "type": "string", "enum": ["rollback_ready", "blocked", "mismatch"] },
    "blocking_reason": { "type": ["string", "null"] },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
