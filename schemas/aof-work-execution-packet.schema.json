{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-org-labs.github.io/aof/schemas/aof-work-execution-packet.schema.json",
  "title": "AOF Work Execution Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "packet_id",
    "recorded_at",
    "work_item_id",
    "work_item_ref",
    "execution_status",
    "context_integrity_ref",
    "actor_handoff_refs",
    "execution_lineage_ref",
    "verification_evidence_refs",
    "stop_continue_decision",
    "not_proven",
    "source_task_id",
    "source_parent_session_id"
  ],
  "properties": {
    "artifact_type": { "const": "work-execution-packet" },
    "packet_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "work_item_id": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "execution_status": {
      "type": "string",
      "enum": ["draft", "ready", "blocked", "completed"]
    },
    "context_integrity_ref": { "type": "string", "minLength": 1 },
    "actor_handoff_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "execution_lineage_ref": { "type": "string", "minLength": 1 },
    "verification_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_continue_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "rationale", "decided_by", "evidence_refs"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["continue", "stop", "defer", "reopen"]
        },
        "rationale": { "type": "string", "minLength": 1 },
        "decided_by": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "not_proven": { "type": "string", "minLength": 1 },
    "source_task_id": { "type": "string", "minLength": 1 },
    "source_parent_session_id": { "type": "string", "minLength": 1 },
    "source_decision_record_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
